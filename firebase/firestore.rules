rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- AUTH CHECKS ---------------- */

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.role == "admin";
    }

    /* ---------------- USERS ---------------- */

    match /users/{userId} {

      allow read: if isOwner(userId);

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if false;
    }

    /* ---------------- PUBLIC DATA ---------------- */

    match /doctors/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /departments/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /packages/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /blog_posts/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    /* ---------------- CONTACT / NEWSLETTER ---------------- */

    match /contacts/{doc} {

      allow create: if true;

      allow read, delete: if isAdmin();
    }

    match /newsletter/{doc} {

      allow create: if true;

      allow read, delete: if isAdmin();
    }

    /* ---------------- APPOINTMENT SLOTS ---------------- */

    match /appointmentSlots/{slotId} {

      /* slot lookup */

      allow read: if true;

      /* booking transaction */

      allow create, update: if isLoggedIn();

      /* deletion restricted */

      allow delete: if isAdmin();
    }

    /* ---------------- APPOINTMENTS ---------------- */

    match /appointments/{appointmentId} {

      /* create booking */

      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid;

      /* slot availability queries */

      allow list: if isLoggedIn();

      /* patient reads own appointment */

      allow get: if isOwner(resource.data.userId) || isAdmin();

      /* update */

      allow update: if
        isOwner(resource.data.userId) ||
        isAdmin();

      /* delete */

      allow delete: if isAdmin();
    }

  }
}