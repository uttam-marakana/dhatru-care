rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ------ AUTH CHECKS ---------------------- */ 

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.role == "admin";
    }

    /* ------ USERS ---------------------- */ 

    match /users/{userId} {

      allow read: if isOwner(userId);

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if false;
    }

    /* ------ PUBLIC DATA ---------------------- */ 

    match /doctors/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /departments/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /packages/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /blog_posts/{doc} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    /* ------ CONTACT / NEWSLETTER ---------------------- */ 

    match /contacts/{doc} {

      allow create: if true;

      allow read, delete: if isAdmin();
    }

    match /newsletter/{doc} {

      allow create: if true;

      allow read, delete: if isAdmin();
    }

    /* ------ APPOINTMENT SLOTS ---------------------- */ 

    match /appointmentSlots/{slotId} {

      allow read: if true;

      allow create, update: if isLoggedIn();

      allow delete: if isAdmin();
    }

    /* ------ APPOINTMENTS ---------------------- */ 

    match /appointments/{appointmentId} {

      /* ------ USER CAN CREATE THEIR OWN APPOINTMENT ------ */

      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid;

      /* ------ USER CAN READ THEIR OWN APPOINTMENTS ------ */

      allow get: if isOwner(resource.data.userId) || isAdmin();

      /* ------ FIX: allow authenticated users to query their appointments ------ */

      allow list: if isLoggedIn();

      /* ------ USER CAN UPDATE THEIR OWN OR ADMIN CAN MANAGE ------ */

      allow update: if isAdmin()
        || (
          isLoggedIn() &&
          request.resource.data.userId == request.auth.uid
        );

      /* ------ ONLY ADMIN CAN DELETE ------ */

      allow delete: if isAdmin();
    }
    
    /* ------ 	Booking Events ---------------------- */ 
    
 		match /bookingEvents/{id} {

      /* ------ ✅ only logged-in users can log events ------ */
      allow create: if isLoggedIn();

      /* ------ ✅ only admin can read analytics ------ */
      allow read: if isAdmin();

      /* ------ ❌ prevent updates/deletes ------ */
      allow update, delete: if false;
    }

  }
}