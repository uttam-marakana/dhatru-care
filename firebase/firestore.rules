rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- AUTH ---------------- */

    function isLoggedIn() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn() && getUser().role == "admin";
    }

    function isSameTenant(resourceTenantId) {
      return isLoggedIn() &&
        getUser().tenantId == resourceTenantId;
    }

    /* ---------------- USERS ---------------- */

    match /users/{userId} {

      allow read: if isOwner(userId);

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if false;
    }

    /* ---------------- PUBLIC DATA ---------------- */

    match /doctors/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departments/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packages/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog_posts/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ---------------- CONTACT / NEWSLETTER ---------------- */

    match /contacts/{doc} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /newsletter/{doc} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    /* ---------------- APPOINTMENT SLOTS ---------------- */

    match /appointmentSlots/{slotId} {

      allow read: if true;

      allow create, update: if isLoggedIn()
        && isSameTenant(request.resource.data.tenantId);

      allow delete: if isAdmin();
    }

    /* ---------------- APPOINTMENTS ---------------- */

    match /appointments/{appointmentId} {

      /* CREATE */
      allow create: if isLoggedIn()
        && request.resource.data.userId == request.auth.uid
        && isSameTenant(request.resource.data.tenantId);

      /* READ SINGLE */
      allow get: if isOwner(resource.data.userId)
        || (isAdmin() && isSameTenant(resource.data.tenantId));

      /* LIST (QUERY) */
      allow list: if isLoggedIn();

      /* UPDATE */
      allow update: if
        (
          isAdmin() &&
          isSameTenant(resource.data.tenantId)
        )
        ||
        (
          isOwner(resource.data.userId) &&
          isSameTenant(resource.data.tenantId)
        );

      /* DELETE */
      allow delete: if isAdmin()
        && isSameTenant(resource.data.tenantId);
    }

    /* ---------------- BOOKING EVENTS ---------------- */

    match /bookingEvents/{id} {

      allow create: if isLoggedIn();

      allow read: if isAdmin();

      allow update, delete: if false;
    }

    /* ---------------- AUDIT LOGS ---------------- */

    match /auditLogs/{id} {

      allow create: if isLoggedIn();

      allow read: if isAdmin();

      allow update, delete: if false;
    }

    /* ---------------- SUBSCRIPTIONS ---------------- */

    match /subscriptions/{tenantId} {

      allow read: if isAdmin();

      allow write: if false; // controlled via backend/admin only
    }

  }
}